# Chain — switch VITE_CHAIN_ID to match your deployment
VITE_CHAIN_ID=1
VITE_RPC_URL=https://ethereum.publicnode.com
VITE_EXPLORER_URL=https://etherscan.io

# Unified UniHash contract (token + NFT + dividends + Uniswap v4 hook)
VITE_UNIHASH=0x82da588a1DcD34aaF726E8833364b21d37C2f70C

# Optional overrides — leave unset to use VITE_UNIHASH for all roles
# VITE_HASH_TOKEN=
# VITE_HASH_REGISTRY=
# VITE_REWARD_DISTRIBUTOR=
VITE_UNISWAP_POOL=0x0000000000000000000000000000000000000000

# Reward read function (withdrawableDividend | claimable | pendingReward | earned)
VITE_DISTRIBUTOR_CLAIM_READ_FN=withdrawableDividend

# Set to true after launch to load live on-chain metrics, gallery, and wallet balances
VITE_LIVE_DATA=false
